{
  "name": "@engine/ui",
  "version": "0.1.0",
  "description": "In-canvas UI toolkit for @engine/core — a retained widget tree, flex layout, bitmap-font text, shade-mask icons, screen-space input dispatch, and a DOM a11y mirror. Renders through the same 2D renderer as the game scene (WebGPU + Canvas2D), fully themeable, game-agnostic.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./render": "./src/render/index.ts",
    "./text": "./src/text/index.ts",
    "./icon": "./src/icon/index.ts",
    "./theme": "./src/theme/index.ts",
    "./layout": "./src/layout/index.ts",
    "./widget": "./src/widget/index.ts",
    "./input": "./src/input/index.ts",
    "./scroll": "./src/scroll/index.ts",
    "./anim": "./src/anim/index.ts",
    "./a11y": "./src/a11y/index.ts"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./render": {
        "types": "./dist/render/index.d.ts",
        "default": "./dist/render/index.js"
      },
      "./text": {
        "types": "./dist/text/index.d.ts",
        "default": "./dist/text/index.js"
      },
      "./icon": {
        "types": "./dist/icon/index.d.ts",
        "default": "./dist/icon/index.js"
      },
      "./theme": {
        "types": "./dist/theme/index.d.ts",
        "default": "./dist/theme/index.js"
      },
      "./layout": {
        "types": "./dist/layout/index.d.ts",
        "default": "./dist/layout/index.js"
      },
      "./widget": {
        "types": "./dist/widget/index.d.ts",
        "default": "./dist/widget/index.js"
      },
      "./input": {
        "types": "./dist/input/index.d.ts",
        "default": "./dist/input/index.js"
      },
      "./scroll": {
        "types": "./dist/scroll/index.d.ts",
        "default": "./dist/scroll/index.js"
      },
      "./anim": {
        "types": "./dist/anim/index.d.ts",
        "default": "./dist/anim/index.js"
      },
      "./a11y": {
        "types": "./dist/a11y/index.d.ts",
        "default": "./dist/a11y/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
    "prepack": "npm run build && node scripts/pack-swap.mjs --to-dist",
    "postpack": "node scripts/pack-swap.mjs --restore",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@engine/core": "0.1.0"
  },
  "devDependencies": {
    "@types/jsdom": "21.1.7",
    "@webgpu/types": "0.1.70",
    "jsdom": "29.1.1",
    "tsx": "4.22.3"
  }
}
