# Farm Valley — Caddy site snippet (NOT a full Caddyfile).
#
# This is a single `handle_path` block, uploaded by `pre-deploy` to a
# per-project snippet path on the server (REMOTE_CADDY_SNIPPET in deploy/.env,
# e.g. /etc/caddy/sites/farm-valley.caddy). Keeping each project in its own
# snippet means deploying Farm Valley never touches other projects on the
# shared VPS.
#
# ONE-TIME server setup: make your main /etc/caddy/Caddyfile import the snippets
# dir from inside the relevant site block, e.g.
#
#   :80 {                      # or:  your-domain.example.com {
#       import sites/*.caddy   # paths are relative to the Caddyfile's dir
#   }
#
# Then create the dir once:  sudo mkdir -p /etc/caddy/sites
# After that, `pre-deploy` drops this file in and reloads Caddy.
#
# handle_path STRIPS the matched /farm-valley prefix before serving, so the
# files live at the ROOT of REMOTE_DIR (e.g. /var/www/farm-valley/index.html),
# not under a nested /farm-valley subdir.

# Bare path without trailing slash → redirect so relative resolution + the
# directory index behave. Without this, "/farm-valley" 404s.
redir /farm-valley /farm-valley/ permanent

handle_path /farm-valley/* {
	root * /var/www/farm-valley
	encode gzip zstd
	# Farm Valley is a single-screen app — there is no client-side router, so we
	# do NOT use a catch-all SPA fallback. A real file or the directory index is
	# served; anything else is an honest 404 (a `try_files … /index.html`
	# fallback would make bogus paths like /farm-valley/farm-valley/ falsely
	# return the app instead of 404ing).
	file_server
}
