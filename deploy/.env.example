SSH_HOST=<ssh-alias>

BASE_PATH=/farm-valley/

REMOTE_DIR=<remote-dir>
PUBLIC_URL=<public-url>
REMOTE_CADDYFILE=<main-caddyfile-path>
REMOTE_CADDY_SNIPPET=<snippet-path>

# Optional explicit SSH connection overrides (otherwise the alias is used).
# SSH_USER=<user>
# SSH_HOSTNAME=<host-or-ip>
# SSH_PORT=<port>
# SSH_KEY=<path-to-key>

#         prompt over a non-interactive SSH channel).
SUDO_NOPASSWD=false
