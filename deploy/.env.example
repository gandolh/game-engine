SSH_HOST=<ssh-alias>

BASE_PATH=/farm-valley/

REMOTE_DIR=<remote-dir>
PUBLIC_URL=<public-url>
REMOTE_CADDYFILE=<main-caddyfile-path>
REMOTE_CADDY_SNIPPET=<snippet-path>

# --- Sim server (brief 58: `deploy server` / `deploy:server`) ---
# Where the Node sim server (@farm/server) is rsynced + run under pm2. The
# Caddy snippet reverse-proxies /farm-valley/sim → localhost:SERVER_PORT.
SERVER_DIR=/srv/farm-valley-sim
PM2_NAME=farm-valley-sim
SERVER_PORT=8787

# Optional explicit SSH connection overrides (otherwise the alias is used).
# SSH_USER=<user>
# SSH_HOSTNAME=<host-or-ip>
# SSH_PORT=<port>
# SSH_KEY=<path-to-key>

#         prompt over a non-interactive SSH channel).
SUDO_NOPASSWD=false
